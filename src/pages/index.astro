---
import { getCollection } from "astro:content";
import { Button } from "opui-css/astro";
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PostCard from "../components/PostCard.astro";

const featuredWork = (
  await getCollection("work", ({ data }) => data.featured)
).sort((a, b) => a.data.order - b.data.order);

const latestPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout>
  <section class="hero container">
    <h1 class="display-xl">Hej, I'm <span class="sunset-text">Felix</span></h1>
    <p class="lede">
      I build for the web. Frontend development, design systems, component
      libraries, you name it. Modern CSS is my weapon of choice.
    </p>
  </section>

  <section class="container">
    <div class="section-head">
      <h2>Things I made</h2>
      <Button as="a" href="/work" data-tiks="click"> All work → </Button>
    </div>
    <div class="work-grid">
      {
        featuredWork.map(({ id, data }) => (
          <ProjectCard
            title={data.title}
            description={data.description}
            slug={id}
            url={data.url}
            image={data.image}
            tag={data.tag}
          />
        ))
      }
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <h2>From the blog</h2>
      <Button as="a" href="/blog" data-tiks="click"> All posts → </Button>
    </div>
    {
      latestPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          href={`/blog/${post.id}`}
        />
      ))
    }
  </section>
</Layout>

<style>
  .hero {
    padding-block: var(--size-9) var(--size-8);

    .lede {
      max-inline-size: 48ch;
      margin-block-start: var(--size-4);
      font-size: var(--font-size-2);
      line-height: 1.6;
    }
  }

  section + section {
    margin-block-start: var(--size-8);
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--size-4);
    margin-block-end: var(--size-4);

    h2 {
      color: var(--accent-1);
    }
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
    gap: var(--_gap);
  }
</style>
