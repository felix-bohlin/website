---
import "@fontsource-variable/fraunces/full.css";
import "@fontsource-variable/fraunces/full-italic.css";
import "/src/styles/main.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type Props = {
  title?: string;
  description?: string;
};

const {
  title,
  description = "Felix Bohlin — frontend developer. Design systems, CSS and the modern web.",
} = Astro.props;

const pageTitle = title ? `${title} · Felix Bohlin` : "Felix Bohlin";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <script is:inline>
      // Apply stored theme before paint to avoid a flash
      const theme = localStorage.getItem("theme");
      if (theme === "dark" || theme === "light") {
        document.documentElement.classList.add(`ui-${theme}`);
      }
    </script>
  </head>
  <body>
    <div class="retro-bg" aria-hidden="true">
      <div class="sunburst"></div>
      <div class="bands"></div>
    </div>
    <svg class="retro-defs" aria-hidden="true" width="0" height="0">
      <filter id="squiggle">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.012"
          numOctaves="2"
          seed="7"
          result="noise"></feTurbulence>
        <feDisplacementMap
          in="SourceGraphic"
          in2="noise"
          scale="140"
          xChannelSelector="R"
          yChannelSelector="G"></feDisplacementMap>
      </filter>
    </svg>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import { init, bindTiks } from "@rexa-developer/tiks";

  init({ theme: "soft", muted: localStorage.getItem("sound") === "off" });
  bindTiks();
</script>

<style>
  .retro-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    opacity: 0.2;
  }

  .retro-defs {
    position: absolute;
    width: 0;
    height: 0;
  }

  /* Hard-edged sunburst rays radiating from a top corner - classic 70s.
     An SVG displacement filter warps the straight rays into squiggles. */
  .sunburst {
    position: absolute;
    inset-block-start: -60vmax;
    inset-inline-end: -40vmax;
    inline-size: 140vmax;
    aspect-ratio: 1;
    filter: url(#squiggle);
    background: conic-gradient(
      from 0deg,
      var(--accent-2) 0deg 12deg,
      transparent 12deg 24deg,
      var(--accent-3) 24deg 36deg,
      transparent 36deg 48deg,
      var(--accent-1) 48deg 60deg,
      transparent 60deg 72deg,
      var(--accent-2) 72deg 84deg,
      transparent 84deg 96deg,
      var(--accent-3) 96deg 108deg,
      transparent 108deg 120deg,
      var(--accent-1) 120deg 132deg,
      transparent 132deg 144deg,
      var(--accent-2) 144deg 156deg,
      transparent 156deg 168deg,
      var(--accent-3) 168deg 180deg,
      transparent 180deg 360deg
    );
    animation: spin calc(120s * var(--motion, 1)) linear infinite;
  }

  /* Bold hard color bands anchored to the bottom of the viewport. */
  .bands {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    block-size: 32vmax;
    background: linear-gradient(
      to top,
      var(--accent-4) 0% 25%,
      var(--accent-1) 25% 50%,
      var(--accent-3) 50% 72%,
      var(--accent-5) 72% 100%
    );
    mask-image: linear-gradient(to top, black 40%, transparent 100%);
  }

  @keyframes spin {
    to {
      rotate: 360deg;
    }
  }

  .skip-link {
    background: var(--surface-elevated);
    border-radius: var(--radius-2);
    inset-block-start: var(--size-2);
    inset-inline-start: var(--size-2);
    padding: var(--size-2) var(--size-3);
    position: absolute;
    z-index: 10;

    &:not(:focus) {
      block-size: 1px;
      clip-path: inset(50%);
      inline-size: 1px;
      overflow: hidden;
      white-space: nowrap;
    }
  }
</style>
